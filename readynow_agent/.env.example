# Set locally for testing. Agent Engine injects GOOGLE_CLOUD_* at deploy time;
# do NOT pass GOOGLE_CLOUD_PROJECT or GOOGLE_CLOUD_LOCATION in env_vars when deploying.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
MAPS_API_KEY=your-maps-api-key
MA_TEMPLATE_ID=readynow-armor
STAGING_BUCKET=gs://your-gcp-project-id-adk-staging
LOG_LEVEL=INFO
